{
  "installed": {
    "client_id": "YOUR_CLIENT_ID.apps.googleusercontent.com",
    "project_id": "your-project-id",
    "auth_uri": "https://accounts.google.com/o/oauth2/auth",
    "token_uri": "https://oauth2.googleapis.com/token",
    "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
    "client_secret": "YOUR_CLIENT_SECRET",
    "redirect_uris": ["http://localhost"]
  }
}

# Save your actual client secret JSON to a file and set environment variable:
#   setx GOOGLE_CLIENT_SECRET_FILE "path\to\client_secret.json"  (Windows)
# or
#   export GOOGLE_CLIENT_SECRET_FILE=/path/to/client_secret.json (Linux/macOS)
# Also set token path if you want:
#   setx GOOGLE_OAUTH_TOKEN_FILE "path\to\token.json"
